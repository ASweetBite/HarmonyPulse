{
  "module": {
    "routerMap": "$profile:route_map",
    "requestPermissions": [
      {
        "name": "ohos.permission.VIBRATE", //振动权限
      },
      {
        "name": "ohos.permission.INTERNET"    //申请网络权限

      },{ "name": "ohos.permission.KEEP_BACKGROUND_RUNNING" //长时任务
      }
    ],
    "name": "entry",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "EntryAbility",

    "deviceTypes": [
      "default",
      "tablet"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",

    "abilities": [
      {
        "backgroundModes": [
          // 长时任务类型的配置项
           "audioPlayback"
        ],
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:EntryAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:EntryAbility_label",
        "startWindowIcon": "$media:logo",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "ohos.want.action.home"
            ]
          }
        ]
      },
      {
        "name": "ShareReceiveAbility", // 1. 这里必须和你的类名一致
        "srcEntry": "./ets/utils/services/MusicReceiveService.ets", // 2. 这里必须指向你写的那个接收分享的文件路径
        "description": "接收分享的Ability",
        "icon": "$media:layered_image",
        "label": "$string:ShareReceive_Lable", // 分享面板上显示的文字
        "startWindowIcon": "$media:logo",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "actions": [
              "ohos.want.action.sendData", // 接收单文件
              "ohos.want.action.sendMultipleData"
            ],
            "uris": [
              {
                "scheme": "file",
                "utd": "general.audio",
                "maxFileSupported": 128
              },
              {
                "scheme": "content", // 3. 必须添加 content 协议支持
                "utd": "general.audio",
                "maxFileSupported": 128
              }
            ]
          }
        ]
      }
    ],
    "extensionAbilities": [
      {
        "name": "EntryBackupAbility",
        "srcEntry": "./ets/entrybackupability/EntryBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ]
      }
    ]
  }
}